# ===============================================================
# VIGIL-AI CAMEROUN - Environment Variables (template)
# Copy to .env and fill in your values.
# ALL services used here are 100% FREE
# ===============================================================

# -- Application ------------------------------------------------
APP_NAME="VIGIL-AI Cameroun"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development
# Base URL for file serving
APP_BASE_URL=http://localhost:8000
# Frontend URL - used to build links that go into emails/notifications
# (password reset, etc). Set this to your real Vercel URL in production.
FRONTEND_URL=http://localhost:5173

# -- Security (generate with: openssl rand -hex 32) -------------
SECRET_KEY=this_will_be_replaced_with_a_secure_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Database (PostgreSQL - Supabase) ---------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=the_password
POSTGRES_DB=postgres
POSTGRES_HOST=the_host
POSTGRES_PORT=6543
DATABASE_URL=postgresql+asyncpg://postgres:the_password@the_host:6543/postgres?ssl=require

# -- Redis (Upstash) --------------------------------------------
REDIS_HOST=the_host.upstash.io
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=rediss://

# -- Celery -----------------------------------------------------
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# -- File Storage (local filesystem - FREE) ---------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/mp3
ALLOWED_VIDEO_TYPES=video/mp4,video/avi,video/quicktime

# -- Google Gemini API (FREE - get key at aistudio.google.com) --
# Create a FREE Google account -> https://aistudio.google.com/apikey
# Free tier (gemini-2.0-flash): 15 req/min, 1M tokens/min, 1500 req/day
# This single API handles text, image, AND audio analysis (multimodal)
# Leave empty to fall through to Hugging Face / built-in detectors
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -- Hugging Face Inference API (FREE - tier 2 of the cascade) --
# Get a token at https://huggingface.co/settings/tokens
# Used when Gemini is unavailable or its daily quota is exhausted.
# Leave empty to skip straight to the built-in forensic algorithms.
# Model slots are comma-separated ensembles (all responsive models vote).
HF_API_KEY=
HF_TEXT_AI_MODELS=Hello-SimpleAI/chatgpt-detector-roberta,openai-community/roberta-base-openai-detector
HF_FAKE_NEWS_MODELS=hamzab/roberta-fake-news-classification
HF_IMAGE_DEEPFAKE_MODELS=dima806/deepfake_vs_real_image_detection,prithivMLmods/Deep-Fake-Detector-v2-Model
# NOTE: HF's free serverless tier currently hosts no audio-deepfake model
# (verified 2026-07). Audio is covered by Gemini + local signal forensics;
# this slot activates automatically if the model becomes available or you
# point it at a dedicated Inference Endpoint.
HF_AUDIO_DEEPFAKE_MODELS=MelodyMachine/Deepfake-audio-detection-V2

# -- Cloudinary (optional media mirroring - FREE tier) ----------
# Create a free account at https://cloudinary.com and paste the
# "API Environment variable" from the dashboard. Leave empty to disable.
CLOUDINARY_URL=
CLOUDINARY_MAX_MB=10

# -- Remote media fetching (URL-based submissions) --------------
URL_FETCH_MAX_MB=25
YTDLP_ENABLED=True
YTDLP_MAX_FILESIZE_MB=60
YTDLP_MAX_DURATION_SECONDS=600

# -- Email (optional for MVP - uses console logging if not set) -
# For testing: leave empty -> emails printed to console
# For real emails: use Gmail SMTP (free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@vigilai.cm
# Set to false to disable email (print to console instead)
EMAIL_ENABLED=False

# -- CORS (Frontend origins allowed) ----------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# -- Rate Limiting ----------------------------------------------
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# -- Analysis Thresholds ----------------------------------------
RISK_SCORE_SAFE_MAX=29
RISK_SCORE_SUSPICIOUS_MAX=69
# >= 70 = MALICIOUS
# 0 = every analyzed submission opens a reviewable case (full coverage);
# raise it to only open cases for higher-risk content.
AUTO_CREATE_CASE_MIN_SCORE=0
